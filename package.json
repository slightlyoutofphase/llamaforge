{
  "name": "llamaforge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run src/server/index.ts\" \"vite\"",
    "build": "vite build && bun build src/server/index.ts --target bun --outdir dist/server",
    "start": "bun run dist/server/index.js",
    "test": "bun test",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "biome lint .",
    "clean": "bun run scripts/clean.mjs",
    "docs": "typedoc"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@huggingface/gguf": "^0.4.2",
    "@huggingface/jinja": "^0.5.7",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.22",
    "@uiw/react-codemirror": "^4.25.9",
    "@vitejs/plugin-react": "~6.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "highlight.js": "^11.11.1",
    "json2gbnf": "^0.1.4",
    "katex": "^0.16.45",
    "lucide-react": "~1.8.0",
    "mathjs": "^15.2.0",
    "mime": "^4.1.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@happy-dom/global-registrator": "^20.9.0",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.12",
    "@types/mime": "^3.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "bun": "^1.3.12",
    "concurrently": "^9.2.1",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.14",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "~6.0.3",
    "vite": "~8.0.8"
  }
}
